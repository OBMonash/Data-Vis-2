{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 675,
    "height": 250,
    "background": "#e9eef1",
    "config": {
        "view": {"stroke": "transparent"}    
    },
    "projection": {"type": "equalEarth"},
    "data": {
        "url": "world-map.topojson", 
        "format": {
            "type": "topojson", "feature": "gj" 
        }
    },
    "params": [
        {
            "name": "metric",
            "value": "all_master_player_count",
            "bind": {
                "input": "select",
                "options": ["all_master_player_count", "total_player_count"],
                "labels": ["Titled players", "Total players"],
                "name": "Select metric: "
            }
        }
    ],
    "transform": [
        {
            "lookup": "properties.NAME",
            "from": {
                "data": {
                    "url": "rated_player_count.csv",
                    "format": {"type": "csv"}
                },
                "key": "Country",
                "fields": ["all_master_player_count", "total_player_count"]
            }
        },
        {
            "calculate": "datum[metric]",
            "as": "selected_value"
        }
    ],
    "mark": {"type": "geoshape"},
    "encoding": {
        "color": {
            "field": "selected_value",
            "type": "quantitative",
            "scale": {
                "type": "threshold",
                "domain": { "signal": "metric == 'all_master_player_count' ? [25,50,100,500,1000] : [200, 500, 1000, 5000, 10000]" },
                "scheme": "redpurple"   
            },
            "legend": {"title": "Number of Players", "type": "symbol", "symbolType": "circle"}
        },
        "tooltip": [
            {"field": "properties.NAME", "type": "nominal", "title": "Country"},
            {"field": "selected_value", "type": "quantitative", "title": "Number of Players"}
        ]
    }
}