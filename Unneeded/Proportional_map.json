{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "background": "#e9eef1",
    "title": "Placeholder",
    "width": 800,
    "height": 400,
    "projection": {"type": "equalEarth"},
    "data": {
        "url": "world-map.topojson", 
        "format": {
            "type": "topojson", "feature": "gj" 
        }
    },
    "transform": [{
        "lookup": "properties.NAME",
        "from": {
            "data": {
                "url": "Country_rating_averages.csv",
                "format": {"type": "csv"}
            },
            "key": "country",
            "fields": ["rating_average"]
        }
    }
    ],
    "mark": {"type": "geoshape"},
    "encoding": {
        "color": {
            "field": "rating_average",
            "type": "quantitative",
            "scale": {"type": "ordinal"},
            "legend": {"title": "Player Rating"}
        },
        "tooltip": [
            {"field": "properties.NAME", "type": "nominal", "title": "Country"},
            {"field": "rating_average", "type": "quantitative", "title": "Rating"}
        ]
    }
}